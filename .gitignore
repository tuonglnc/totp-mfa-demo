# ============================================================
# .gitignore — TOTP MFA Demo
# ============================================================

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual Environment ────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── QUAN TRỌNG: File bí mật — KHÔNG BAO GIỜ commit ────────
.env
*.env
secrets.txt

# ── Database ───────────────────────────────────────────────
database/*.db
database/*.db-shm
database/*.db-wal
*.sqlite
*.sqlite3

# ── Pytest / Coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
pytest_cache/

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Build / Distribution ──────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────
.DS_Store
Desktop.ini
