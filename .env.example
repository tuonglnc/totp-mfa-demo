# ============================================================
# .env.example — Copy to .env and fill in real values
# IMPORTANT: Never commit .env to version control
# ============================================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-long-random-secret-key

# Master key for AES-256-GCM encryption of TOTP secrets
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOTP_MASTER_KEY=change-me-to-another-long-random-key

# Flask environment: development | production
FLASK_ENV=development

# Database path (relative to project root)
DATABASE_PATH=database/mfa_demo.db

# Application issuer name shown in authenticator apps
TOTP_ISSUER=TDTU-InfoSec-MFA

# Rate limiting: number of allowed TOTP attempts per 30s window
TOTP_MAX_ATTEMPTS_PER_WINDOW=5

# Account lockout thresholds
LOCKOUT_TIER1_ATTEMPTS=5
LOCKOUT_TIER1_MINUTES=15
LOCKOUT_TIER2_ATTEMPTS=10
LOCKOUT_TIER2_MINUTES=60
LOCKOUT_TIER3_ATTEMPTS=20
LOCKOUT_TIER3_HOURS=24
